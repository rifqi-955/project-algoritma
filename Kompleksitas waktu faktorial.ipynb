      "source": [
        "\n",
        "def faktorial(n):\n",
        "    if n < 0:\n",
        "        return \"Input harus bilangan bulat positif\"\n",
        "    hasil = 1\n",
        "    for i in range(2, n + 1):\n",
        "        hasil *= i\n",
        "    return hasil\n",
        "\n",
        "\n",
        "a = int(input(\"masukkan angka: \"))\n",
        "print(f\"Faktorial dari {a} adalah {faktorial(a)}\")\n",
        "\n",
        "# Kompleksitas Waktu: O(n)"
      ],
